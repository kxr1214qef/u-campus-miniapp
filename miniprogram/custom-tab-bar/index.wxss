.tabbar-wrap {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  width: 100%;
  box-sizing: border-box;
  padding: 0 20rpx constant(safe-area-inset-bottom);
  padding: 0 20rpx env(safe-area-inset-bottom);
  background: linear-gradient(180deg, rgba(251, 247, 239, 0) 0%, rgba(251, 247, 239, 0.92) 36%, rgba(251, 247, 239, 0.98) 100%);
  pointer-events: none;
}

.tabbar-panel {
  position: relative;
  width: 100%;
  height: 126rpx;
  border-radius: 22rpx 22rpx 0 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 253, 248, 0.98) 100%);
  border: 2rpx solid rgba(232, 220, 199, 0.9);
  border-bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 12rpx 18rpx 14rpx;
  box-shadow: 0 -10rpx 24rpx rgba(89, 58, 27, 0.09), inset 0 4rpx 0 rgba(255, 255, 255, 0.64);
  pointer-events: auto;
}

.tabbar-panel::before {
  content: "";
  position: absolute;
  top: 8rpx;
  left: 28rpx;
  right: 28rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: rgba(139, 103, 61, 0.16);
}

.tab-item {
  flex: 1;
  min-width: 0;
  height: 98rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: transform 150ms ease, background-color 150ms ease;
}

.tab-item:active {
  transform: translateY(2rpx) scale(0.97);
}

.tab-icon-wrap {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  transform-origin: center center;
  transition: transform 160ms ease;
}

.tab-dot {
  position: absolute;
  top: -2rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #be4e33;
  border: 3rpx solid #fff5df;
  box-shadow: 0 4rpx 8rpx rgba(190, 78, 51, 0.28);
}

.tab-text {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #7a654c;
  font-weight: 700;
}

.tab-item.active {
  background: rgba(47, 90, 59, 0.08);
}

.tab-item.active .tab-text {
  color: #2f5a3b;
  font-weight: 900;
}

.tab-item.active .tab-icon {
  transform: translateY(-3rpx) scale(1.08);
}
