.admin-page {
  padding-top: calc(env(safe-area-inset-top) + 100rpx);
  background:
    radial-gradient(circle at 12% 8%, rgba(244, 199, 107, 0.18) 0%, rgba(244, 199, 107, 0) 30%),
    radial-gradient(circle at 88% 12%, rgba(63, 95, 59, 0.12) 0%, rgba(63, 95, 59, 0) 28%),
    linear-gradient(180deg, #fff9ef 0%, #fbf7ef 100%);
}

.admin-card,
.request-card {
  padding: 28rpx;
}

.request-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 20rpx;
}

.request-top,
.request-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.request-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #4a3425;
}

.request-line {
  margin-top: 12rpx;
  color: #7b6652;
  line-height: 1.7;
}

.card-image {
  width: 100%;
  height: 320rpx;
  border-radius: 24rpx;
  margin-top: 18rpx;
  background: #fff6e8;
  border: 2rpx solid rgba(230, 210, 168, 0.76);
}

.request-actions {
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  box-shadow: 0 8rpx 14rpx rgba(139, 94, 52, 0.1);
}

.action-btn:active {
  transform: translateY(1rpx);
  box-shadow: 0 4rpx 8rpx rgba(139, 94, 52, 0.08);
}

.field-tip {
  margin-top: 10rpx;
  color: #7b6652;
  line-height: 1.7;
}
