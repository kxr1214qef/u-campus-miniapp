.login-page {
  padding-top: calc(env(safe-area-inset-top) + 26rpx);
  background:
    radial-gradient(circle at 10% 8%, rgba(244, 199, 107, 0.18) 0%, rgba(244, 199, 107, 0) 30%),
    radial-gradient(circle at 88% 14%, rgba(63, 95, 59, 0.12) 0%, rgba(63, 95, 59, 0) 28%),
    linear-gradient(180deg, #fff9ef 0%, #fbf7ef 100%);
}

.login-card {
  padding: 30rpx;
}

.init-btn {
  margin-top: 24rpx;
}

.avatar-block {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-btn {
  width: 156rpx;
  height: 156rpx;
  padding: 0;
  border-radius: 50%;
  background: transparent;
}

.profile-avatar {
  width: 156rpx;
  height: 156rpx;
  border-radius: 50%;
  background: #fff6e8;
  border: 4rpx solid rgba(230, 210, 168, 0.95);
}

.avatar-tip {
  margin-top: 14rpx;
  color: #7b6652;
  font-size: 24rpx;
}

.field-block {
  margin-top: 28rpx;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #4a3425;
}

.short-textarea {
  min-height: 180rpx;
}

.field-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7b6652;
}

.save-btn {
  margin-top: 34rpx;
}

.dev-box {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #fffdf8;
  border: 2rpx dashed rgba(139, 94, 52, 0.22);
}

.openid-text {
  margin-top: 8rpx;
  color: #7b6652;
}
