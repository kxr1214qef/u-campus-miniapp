.feedback-page {
  min-height: 100vh;
  padding-top: calc(env(safe-area-inset-top) + 92rpx);
  padding-bottom: 44rpx;
  background:
    radial-gradient(circle at 8% 8%, rgba(244, 199, 107, 0.22) 0%, transparent 32%),
    radial-gradient(circle at 90% 16%, rgba(63, 95, 59, 0.12) 0%, transparent 30%),
    linear-gradient(180deg, #fff9ef 0%, #fbf7ef 100%);
}

.page-top {
  margin-bottom: 20rpx;
}

.feedback-hero {
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(255, 246, 232, 0.92));
}

.hero-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #4a3425;
}

.hero-desc {
  margin-top: 14rpx;
  color: #7b6652;
  line-height: 1.7;
}

.form-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 2rpx solid rgba(230, 210, 168, 0.92);
}

.field-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #4a3425;
}

.feedback-textarea {
  box-sizing: border-box;
  width: 100%;
  min-height: 300rpx;
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 2rpx solid #e6d2a8;
  color: #4a3425;
  line-height: 1.7;
}

.text-count {
  margin-top: 10rpx;
  text-align: right;
  color: #9b856d;
  font-size: 22rpx;
}

.submit-btn {
  margin-top: 28rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3f5f3b 0%, #2f472c 100%);
  color: #fff6de;
  font-weight: 800;
  box-shadow: 0 16rpx 28rpx rgba(63, 95, 59, 0.2);
}
