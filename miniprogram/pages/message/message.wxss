.message-page {
  padding-top: calc(env(safe-area-inset-top) + 86rpx);
  background:
    radial-gradient(circle at 88% 8%, rgba(244, 199, 107, 0.08) 0%, transparent 26%),
    radial-gradient(circle at 10% 14%, rgba(63, 95, 59, 0.05) 0%, transparent 30%),
    linear-gradient(180deg, #fffdf9 0%, #fbf8f2 100%);
}

.message-summary {
  padding: 26rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #ffffff 0%, #fffdf8 100%);
  border: 2rpx solid rgba(232, 220, 199, 0.82);
  box-shadow: 0 8rpx 22rpx rgba(92, 62, 31, 0.05);
}

.conversation-list {
  margin-top: 8rpx;
}

.conversation-card {
  display: flex;
  align-items: center;
  padding: 22rpx;
  margin-top: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf9 100%);
  border: 2rpx solid rgba(232, 220, 199, 0.78);
  box-shadow: 0 8rpx 22rpx rgba(92, 62, 31, 0.05);
}

.conv-avatar {
  width: 88rpx;
  height: 88rpx;
  flex-shrink: 0;
}

.conv-main {
  flex: 1;
  min-width: 0;
  margin-left: 18rpx;
}

.conv-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.conv-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #4a3425;
}

.conv-time {
  font-size: 22rpx;
  color: #9b856d;
}

.conv-preview {
  margin-top: 10rpx;
  color: #8d7b69;
}

.goods-mini-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  padding: 12rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid rgba(232, 220, 199, 0.68);
}

.goods-mini-cover {
  width: 74rpx;
  height: 74rpx;
  border-radius: 16rpx;
  background: #fbf7ef;
  flex-shrink: 0;
}

.goods-mini-info {
  flex: 1;
  min-width: 0;
  margin-left: 14rpx;
  font-size: 24rpx;
}

.goods-count {
  flex-shrink: 0;
  margin-left: 12rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f5f0e7;
  color: #3f5f3b;
  font-size: 21rpx;
  font-weight: 700;
}

.unread-badge {
  min-width: 40rpx;
  height: 40rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #d98b3a;
  color: #fff6de;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  margin-left: 14rpx;
}

.message-login-btn {
  margin-top: 28rpx;
}
