.profile-page {
  padding-top: calc(env(safe-area-inset-top) + 100rpx);
  background:
    radial-gradient(circle at 8% 6%, rgba(244, 199, 107, 0.22) 0%, transparent 30%),
    radial-gradient(circle at 92% 18%, rgba(63, 95, 59, 0.12) 0%, transparent 28%),
    linear-gradient(180deg, #fff9ef 0%, #fbf7ef 100%);
}

.account-card {
  padding: 34rpx 30rpx;
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 246, 232, 0.92) 100%);
  border: 2rpx solid rgba(230, 210, 168, 0.95);
}

.account-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff6e8;
  border: 4rpx solid rgba(230, 210, 168, 0.95);
  flex-shrink: 0;
}

.account-main {
  flex: 1;
  margin-left: 20rpx;
}

.account-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #4a3425;
}

.account-signature {
  margin-top: 12rpx;
  line-height: 1.8;
  color: #7b6652;
}

.account-action {
  margin-top: 12rpx;
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #3f5f3b;
  color: #fff6de;
  font-size: 23rpx;
  font-weight: 700;
}

.account-arrow {
  margin-left: 18rpx;
  font-size: 44rpx;
  color: #8b5e34;
}

.info-row {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
}

.info-card {
  flex: 1;
  padding: 30rpx 20rpx;
  text-align: center;
  border: 2rpx solid rgba(230, 210, 168, 0.92);
}

.info-value {
  font-size: 42rpx;
  font-weight: 700;
  color: #3f5f3b;
}

.info-value.small {
  font-size: 32rpx;
}

.info-label {
  margin-top: 10rpx;
  color: #7b6652;
}

.menu-card {
  margin-top: 22rpx;
  padding: 0 24rpx;
  border: 2rpx solid rgba(230, 210, 168, 0.92);
}

.menu-item {
  padding: 28rpx 0;
  border-bottom: 2rpx solid rgba(230, 210, 168, 0.72);
  display: flex;
  align-items: center;
}

.menu-item.last {
  border-bottom: none;
}

.menu-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #4a3425;
}

.menu-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7b6652;
  line-height: 1.7;
}

.menu-arrow {
  margin-left: auto;
  font-size: 40rpx;
  color: #9b856d;
}
