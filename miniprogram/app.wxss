page {
  background:
    radial-gradient(circle at 12% 8%, rgba(244, 199, 107, 0.08) 0%, rgba(244, 199, 107, 0) 30%),
    radial-gradient(circle at 88% 12%, rgba(63, 95, 59, 0.06) 0%, rgba(63, 95, 59, 0) 28%),
    linear-gradient(180deg, #fff9ef 0%, #fbf7ef 100%);
  color: #4a3425;
  font-size: 28rpx;
}

view,
text,
input,
textarea,
image,
button,
scroll-view,
swiper,
swiper-item {
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: calc(env(safe-area-inset-top) + 26rpx) 28rpx calc(48rpx + env(safe-area-inset-bottom));
}

.with-tabbar {
  padding-bottom: calc(180rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.page-market {
  background:
    radial-gradient(circle at 10% 8%, rgba(244, 199, 107, 0.08) 0%, rgba(244, 199, 107, 0) 30%),
    radial-gradient(circle at 90% 14%, rgba(63, 95, 59, 0.06) 0%, rgba(63, 95, 59, 0) 28%),
    linear-gradient(180deg, #fff9ef 0%, #fbf7ef 100%);
  color: #4a3425;
}

.card,
.paper-card {
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
  border: 2rpx solid #e8dcc7;
  border-radius: 28rpx;
  box-shadow: 0 10rpx 24rpx rgba(92, 62, 31, 0.07), inset 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #4a3425;
}

.section-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7b6652;
}

.primary-btn,
.market-btn-primary {
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3f5f3b 0%, #2f472c 100%);
  color: #fff9ef;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(47, 71, 44, 0.92);
  padding: 0 32rpx;
  box-shadow: 0 12rpx 24rpx rgba(63, 95, 59, 0.24), inset 0 2rpx 0 rgba(255, 255, 255, 0.16);
  transition: transform 150ms ease, box-shadow 150ms ease;
}

.primary-btn:active,
.market-btn-primary:active {
  transform: translateY(1rpx) scale(0.98);
  box-shadow: 0 7rpx 15rpx rgba(63, 95, 59, 0.2);
}

.primary-btn::after,
.ghost-btn::after,
.market-btn-primary::after,
.market-btn-secondary::after,
.market-btn-danger::after,
.icon-btn::after,
.avatar-btn::after {
  border: none;
}

.ghost-btn,
.market-btn-secondary {
  height: 80rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fff6e8 100%);
  color: #3f5f3b;
  border: 2rpx solid #e4d3b2;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  box-shadow: 0 8rpx 16rpx rgba(139, 94, 52, 0.1);
  transition: transform 150ms ease, box-shadow 150ms ease;
}

.ghost-btn:active,
.market-btn-secondary:active {
  transform: scale(0.98);
  background: #fff0d9;
  box-shadow: 0 4rpx 10rpx rgba(139, 94, 52, 0.1);
}

.danger-btn,
.market-btn-danger {
  height: 80rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #c76a55 0%, #b85c4a 100%);
  color: #fff9ef;
  border: 2rpx solid rgba(142, 63, 49, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  box-shadow: 0 8rpx 14rpx rgba(184, 92, 74, 0.16);
  transition: transform 150ms ease, box-shadow 150ms ease;
}

.danger-btn:active,
.market-btn-danger:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 8rpx rgba(184, 92, 74, 0.12);
}

.danger-btn::after {
  border: none;
}

.text-link {
  color: #3f5f3b;
  font-size: 24rpx;
  font-weight: 700;
}

.tag-chip,
.market-tag {
  padding: 14rpx 24rpx;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf8 100%);
  color: #7b6652;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(232, 220, 199, 0.92);
  box-shadow: 0 5rpx 10rpx rgba(139, 94, 52, 0.04);
}

.tag-chip.active,
.market-tag-active {
  background: linear-gradient(135deg, #3f5f3b 0%, #2f472c 100%);
  color: #fff9ef;
  font-weight: 700;
  border: 2rpx solid rgba(47, 71, 44, 0.82);
  box-shadow: 0 8rpx 18rpx rgba(63, 95, 59, 0.16);
}

.empty-wrap {
  padding: 88rpx 36rpx;
  text-align: center;
  color: #7b6652;
}

.empty-title {
  font-size: 32rpx;
  color: #4a3425;
  font-weight: 700;
}

.empty-desc {
  margin-top: 14rpx;
  line-height: 1.8;
}

.price-text {
  color: #b8402f;
  font-size: 36rpx;
  font-weight: 700;
}

.muted {
  color: #7b6652;
}

.line-1 {
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.line-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff6e8;
  border: 2rpx solid rgba(232, 220, 199, 0.9);
}

.input-box,
.textarea-box,
.paper-input {
  width: 100%;
  border-radius: 24rpx;
  background: #fffdf8;
  border: 2rpx solid #e8dcc7;
  color: #4a3425;
  font-size: 28rpx;
}

.input-box {
  height: 96rpx;
  padding: 0 28rpx;
  line-height: 96rpx;
}

.textarea-box {
  min-height: 240rpx;
  padding: 24rpx 28rpx;
  line-height: 1.8;
}

.input-placeholder {
  color: #9b856d;
  font-size: 26rpx;
}

.status-badge {
  padding: 10rpx 18rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  background: #fff6e8;
  color: #7b6652;
  border: 2rpx solid rgba(230, 210, 168, 0.82);
}

.status-on {
  background: #edf3e7;
  color: #3f5f3b;
}

.status-sold {
  background: #fff1ce;
  color: #8b5e34;
}

.status-off {
  background: #f3eee6;
  color: #7b6652;
}

.simple-topbar {
  display: flex;
  align-items: center;
  margin-top: 70rpx;
  margin-bottom: 22rpx;
}

.back-chip {
  min-width: 192rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 246, 232, 0.98) 100%);
  color: #3f5f3b;
  font-size: 27rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(232, 220, 199, 0.95);
  box-shadow: 0 10rpx 22rpx rgba(139, 94, 52, 0.1);
}

.back-chip.light {
  background: rgba(255, 255, 255, 0.96);
  border-color: rgba(232, 220, 199, 0.92);
  box-shadow: 0 8rpx 18rpx rgba(139, 94, 52, 0.1);
}

.market-illust {
  position: relative;
  width: 100rpx;
  height: 78rpx;
  transform-origin: center bottom;
}

.illust-part {
  position: absolute;
  box-sizing: border-box;
  border: 3rpx solid #4a3425;
  box-shadow: 0 3rpx 0 rgba(74, 52, 37, 0.08);
}

